# Discord Bot Configuration (Vibe Coding Hive Bridge)
# 이 파일을 .env로 이름을 변경하고 실제 값을 입력하세요.

DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 8개 터미널별 채널 ID (디스코드 채널 우클릭 -> 채널 ID 복사)
DISCORD_CHANNEL_T1=CHANNEL_ID_T1
DISCORD_CHANNEL_T2=CHANNEL_ID_T2
DISCORD_CHANNEL_T3=CHANNEL_ID_T3
DISCORD_CHANNEL_T4=CHANNEL_ID_T4
DISCORD_CHANNEL_T5=CHANNEL_ID_T5
DISCORD_CHANNEL_T6=CHANNEL_ID_T6
DISCORD_CHANNEL_T7=CHANNEL_ID_T7
DISCORD_CHANNEL_T8=CHANNEL_ID_T8

# Gemini 모델 분리 설정 (백그라운드 자동 전환용)
# GEMINI_MAIN_MODEL: 복잡한 설계, 분석, 계획용 (기본: gemini-2.0-flash)
GEMINI_MAIN_MODEL=gemini-2.0-flash
# GEMINI_BACKGROUND_MODEL: 단순 요약, 검색, 조회용 (기본: gemini-1.5-flash)
GEMINI_BACKGROUND_MODEL=gemini-1.5-flash

# Codex 모델 분리 설정 (백그라운드 자동 전환용)
# CODEX_MAIN_MODEL: 복잡한 코드 수정, 구현용 (기본: o3-mini)
CODEX_MAIN_MODEL=o3-mini
# CODEX_BACKGROUND_MODEL: 단순 코드 조회, 요약용 (기본: o4-mini)
CODEX_BACKGROUND_MODEL=o4-mini
